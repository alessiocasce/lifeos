# Frontend public Supabase config. Safe for Vite/browser use.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only API config. Never expose these with a VITE_ prefix.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-server-only
LIFEOS_ACTION_TOKEN=generate-a-long-random-token
LIFEOS_ACTION_USER_ID=target-supabase-auth-user-uuid
GEMINI_API_KEY=your-gemini-api-key-server-only
# Optional. Defaults to gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash
